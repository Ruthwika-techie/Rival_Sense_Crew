# ── LLM Provider ────────────────────────────────────────────────────────────
# Use OpenRouter (recommended) or OpenAI directly.
# For OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1
# For OpenAI:      leave OPENAI_BASE_URL blank or remove it

OPENAI_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# ── Search ───────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-YOUR_TAVILY_KEY_HERE

# ── Scraping (optional) ──────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-YOUR_FIRECRAWL_KEY
FIRECRAWL_ENABLED=false

# ── Execution Limits ─────────────────────────────────────────────────────────
MAX_SOURCES=20           # Maximum URLs the researcher can collect
MAX_STEPS=50             # Maximum LangGraph steps before force-stop
MAX_SEARCH_RESULTS=5     # Results per Tavily query
SEARCH_QUERIES_PER_RUN=4 # Number of distinct search queries per topic

# ── Source Quality Gate ───────────────────────────────────────────────────────
# Minimum number of trusted (non-failed, non-empty snippet) sources required
# before the Analyst and Writer run. If fewer are found the pipeline returns a
# structured "No Sufficient Data" response instead of hallucinating content.
MIN_TRUSTED_SOURCES=2

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
